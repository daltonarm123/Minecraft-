{
  "name": "Minecraft ServerCore Java 21",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle",
        "eamodio.gitlens"
      ]
    }
  },
  "postCreateCommand": "cd server-core && gradle test",
  "remoteUser": "vscode"
}
